# Required
JWT_SECRET=change-me-in-production-min-32-chars-long

# Optional — recommended to avoid SODA per-IP throttling
SODA_APP_TOKEN=

# Optional — enables Croma detail enrichment when set
CROMA_API_KEY=

# API config (optional, sensible defaults)
PORT=3000
DATABASE_PATH=./data/portal.sqlite
JWT_EXPIRES_IN=1h
# SECOP dataset resource id on datos.gov.co (SODA)
# p6dx-8zbt = "SECOP II - Procesos de Contratación"
SODA_DATASET=p6dx-8zbt
